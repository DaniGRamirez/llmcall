#!/usr/bin/env bash
set -e

PORT="${LLMCALL_PORT:-3456}"
URL="http://127.0.0.1:${PORT}/call"

if [ -z "$1" ]; then
  echo "Usage: llmcall-fast <prompt> [tier] [system]" >&2
  echo "  llmcall-fast \"summarize this\" local \"one sentence\"" >&2
  exit 1
fi

PROMPT="$1"
TIER="${2:-budget}"
SYSTEM="${3:-}"

# Build JSON payload
if [ -n "$SYSTEM" ]; then
  BODY="{\"prompt\":\"$PROMPT\",\"tier\":\"$TIER\",\"system\":\"$SYSTEM\"}"
else
  BODY="{\"prompt\":\"$PROMPT\",\"tier\":\"$TIER\"}"
fi

# Check if server is running, start if needed
if ! curl -s -f "http://127.0.0.1:${PORT}/health" > /dev/null 2>&1; then
  llmcall serve &
  disown
  # Wait for server to be ready (max 5s)
  for i in $(seq 1 50); do
    curl -s -f "http://127.0.0.1:${PORT}/health" > /dev/null 2>&1 && break
    sleep 0.1
  done
  echo "⚡ llmcall server started" >&2
fi

# Call server, extract result
RESPONSE=$(curl -s -f "$URL" -H "Content-Type: application/json" -d "$BODY" 2>&1) || {
  echo "Error: could not reach llmcall server" >&2
  exit 1
}

# Extract result — use node for reliable JSON parsing (no module loading)
echo "$RESPONSE" | node -e "process.stdin.on('data',d=>{const r=JSON.parse(d);process.stdout.write(r.result||r.error)})"
