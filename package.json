{
  "name": "llmcall",
  "version": "0.1.0",
  "description": "Unified LLM call CLI and library",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "llmcall": "dist/cli.js",
    "llmcall-fast": "bin/llmcall-fast"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "ai": "^4.1.0",
    "@ai-sdk/anthropic": "^1.1.0",
    "@ai-sdk/openai": "^1.1.0",
    "ollama-ai-provider": "^1.2.0",
    "yaml": "^2.8.2",
    "yargs": "^17.7.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/yargs": "^17.0.33",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
